      ]
    },
    {
      "parameters": {
        "numberInputs": 5
      },
      "id": "9fc3641f-7d3e-4c64-ab1d-528495470892",
      "name": "Merge Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.1,
      "position": [
        1888,
        768
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse comma-separated job titles into individual terms\nconst rawQuery = ($('Set Query').first().json.query || '').trim();\nconst terms = rawQuery\n  .split(',')\n  .map(t => t.trim())\n  .filter(t => t.length > 0);\n\nconst allJobs = items\n  .map(i => i.json)\n  .filter(j => j.title)\n  .map((j, idx) => ({\n    id: idx + 1,\n    title: j.title || '',\n    description: (j.description || '').slice(0, 400),\n    url: j.url || '',\n    date: j.date || '',\n    source: j.source || ''\n  }));\n\n// Pre-filter: keep only jobs that loosely match at least one term\n// (reduces token count sent to AI — AI does the precise relevance ranking)\nconst lowerTerms = terms.map(t => t.toLowerCase());\nconst filtered = allJobs.filter(j => {\n  const haystack = (j.title + ' ' + j.description).toLowerCase();\n  return lowerTerms.some(t => haystack.includes(t));\n});\n\n// If pre-filter is too strict (< 5 hits), fall back to all jobs so AI has enough to work with\nconst jobsForAI = filtered.length >= 5 ? filtered : allJobs;\n\nconst humanMessage =\n  `المسميات الوظيفية المطلوبة (${terms.length}): ${terms.map(t => `«${t}»`).join(' | ')}\\n` +\n  `إجمالي الوظائف المتاحة: ${jobsForAI.length} (من أصل ${allJobs.length})\\n\\n` +\n  `قائمة الوظائف:\\n${JSON.stringify(jobsForAI, null, 2)}`;\n\nreturn [{ json: { terms, rawQuery, humanMessage, totalJobs: jobsForAI.length } }];"
      },
      "id": "90a0f67c-b078-4140-8e62-35f2c16017c0",
      "name": "Prepare for AI",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2112,
        752
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.humanMessage }}",
        "options": {
          "systemMessage": "أنت مساعد ذكي متخصص في البحث عن الوظائف في السوق السعودي.\n\nسيُرسَل إليك قائمة وظائف ومجموعة من المسميات الوظيفية المطلوبة.\n\nمهمتك:\n1. لكل مسمى وظيفي مطلوب، ابحث في القائمة عن الوظائف ذات الصلة — افهم المسميات بذكاء:\n   - «محاسب» يشمل: مسؤول مالي، محلل مالي، أمين صندوق، مراجع حسابات\n   - «مطور ERP» يشمل: SAP، Oracle، Microsoft Dynamics، مطور أنظمة\n   - «محلل بيانات» يشمل: data analyst، تحليل البيانات، ذكاء اصطناعي، Power BI، SQL\n   - «مطور BI» يشمل: Business Intelligence، Power BI، Tableau، تقارير، لوحات بيانات\n   - وهكذا لأي مسمى آخر يُرسَل إليك\n2. نسّق الرد بهذه الطريقة:\n   - عنوان رئيسي لكل مسمى: 🔎 *نتائج: «المسمى»*\n   - اعرض بحد أقصى 5 وظائف لكل مسمى، مرتبة من الأعلى صلة للأدنى\n   - اذكر «لا توجد نتائج» للمسمى الذي لا يجد له وظائف\n3. شكل كل وظيفة:\n\n📌 *العنوان*\n📝 الوصف (جملة أو جملتين فقط، احذفه إن كان فارغاً)\n🔗 الرابط\n📅 التاريخ\n🌐 المصدر\n\n4. لا تكرر نفس الوظيفة تحت مسميين مختلفين.\n5. لا تخترع بيانات — استخدم فقط ما في القائمة.\n6. اكتب ردّك كاملاً باللغة العربية."
        }
      },
