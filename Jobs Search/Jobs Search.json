      "parameters": {
        "jsCode": "// jadarat.sa لا يعيد محتوى HTML بدون تشغيل JavaScript (يحتاج Headless Browser).\n// لذلك نعيد قائمة فارغة حالياً حتى لا يتسبب في كسر باقي الفروع.\nreturn [];"
      },
      "id": "70be4a1c-65b8-4152-b6a7-4c2edf9b6d06",
      "name": "Format Jadarat",
      "type": "n8n-nodes-base.code",
